-- ─── AUTO SPAM PARRY - CONNECTED TO BOTH LOBBY AP AND AUTO PARRY ──────────────
local AutoSpamParryEnabled = false
local AutoSpamParryConnection = nil
local ProximityTriggerDistance = 30
local IsAutoSpamActive = false

local function StartAutoSpamParry()
	if AutoSpamParryConnection then return end

	AutoSpamParryConnection = RunService.PreSimulation:Connect(function()
		if not AutoSpamParryEnabled then
			IsAutoSpamActive = false
			if AutoSpamParryConnection then
				AutoSpamParryConnection:Disconnect()
				AutoSpamParryConnection = nil
			end
			return
		end

		local ball = AutoParry.GetBall()
		if not ball then
			IsAutoSpamActive = false
			return
		end

		local ballTarget = ball:GetAttribute('target')
		local zoomies = ball:FindFirstChild('zoomies')
		if not zoomies then
			IsAutoSpamActive = false
			return
		end

		-- ✓ CONNECTED TO BOTH: Triggers if EITHER Lobby AP OR Auto Parry failed 3+ times
		local totalFailures = LobbyCloseRangeCounter + AutoParryCloseRangeCounter
		local distance = (LocalPlayer.Character.PrimaryPart.Position - ball.Position).Magnitude
		local speed = zoomies.VectorVelocity.Magnitude

		-- Activate if failed enough times AND within range
		if ballTarget == tostring(LocalPlayer) and totalFailures >= MAX_CLOSE_RANGE_ATTEMPTS and distance <= ProximityTriggerDistance then
			IsAutoSpamActive = true
			
			-- Continuous spam based on ball speed
			if next(ParryRemotes) then
				AutoParry.PerformRemoteParry(SelectedParryType)
				Parries += 1
				
				-- Vary spam speed based on ball velocity
				local spamDelay = 0.05
				if speed > 700 then
					spamDelay = 0.015
				elseif speed > 600 then
					spamDelay = 0.02
				elseif speed > 500 then
					spamDelay = 0.025
				elseif speed > 400 then
					spamDelay = 0.03
				elseif speed > 300 then
					spamDelay = 0.04
				end
				
				-- Small wait to prevent overwhelming
				task.wait(spamDelay)
			end
		else
			-- ✓ SMOOTH TRANSITION: Don't just stop, reset counters when exiting
			if IsAutoSpamActive then
				print("[AUTO_SPAM] Exiting spam mode - ball distance: " .. tostring(math.floor(distance)) .. " speed: " .. tostring(math.floor(speed)))
				-- Reset counters so Auto Parry gets a fresh start
				LobbyCloseRangeCounter = 0
				AutoParryCloseRangeCounter = 0
			end
			IsAutoSpamActive = false
		end
	end)
end

local function StopAutoSpamParry()
	IsAutoSpamActive = false
	if AutoSpamParryConnection then
		AutoSpamParryConnection:Disconnect()
		AutoSpamParryConnection = nil
	end
end

