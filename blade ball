local function EnsureModifications()
	local char = LocalPlayer.Character
	if not char then return end
	local head = char:FindFirstChild("Head")
	if head then
		head.Transparency = 1
		for _, c in pairs(head:GetChildren()) do if c:IsA("Decal") then c:Destroy() end end
	end
	local rl = char:FindFirstChild("Right Leg")
	if rl then rl.Transparency = 1; rl.CanCollide = false end
	if not char:FindFirstChild("KorbloxLeg") then Korbloxify(char) end
end

