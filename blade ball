function AutoParry_Improved.PredictTrajectory(ballPos, ballVel, playerPos, playerVel, ping, steps)
	steps = steps or 3
	local predictions = {}
	local timeStep = (ping / 1000) / steps
	for i = 1, steps do
		local t = i * timeStep
		local predictedBallPos = ballPos + (ballVel * t)
		local predictedPlayerPos = playerPos + (playerVel * t)
		local distance = (predictedPlayerPos - predictedBallPos).Magnitude
		table.insert(predictions, {
			ballPos = predictedBallPos,
			playerPos = predictedPlayerPos,
			distance = distance,
			time = t
		})
	end
	return predictions
end

function AutoParry_Improved.CalculateAdaptiveSpeedDivisor(speed, speedDivisorMultiplier, distance, ping)
	local cappedSpeed = math.min(math.max(speed - 9.5, 0), 1500)
	local baseDivisor = 2.4 + (cappedSpeed * 0.0016)
	local speedFactor = 1.0
	
	if speed >= SPEED_BRACKETS.HYPERSONIC then speedFactor = 0.65
	elseif speed >= SPEED_BRACKETS.EXTREME then speedFactor = 0.70
	elseif speed >= SPEED_BRACKETS.VERY_FAST then speedFactor = 0.80
	elseif speed >= SPEED_BRACKETS.FAST then speedFactor = 0.90
	elseif speed >= SPEED_BRACKETS.MEDIUM_FAST then speedFactor = 0.95
	elseif speed >= SPEED_BRACKETS.MEDIUM then speedFactor = 1.0
	elseif speed >= SPEED_BRACKETS.SLOW then speedFactor = 1.15
	elseif speed >= SPEED_BRACKETS.VERY_SLOW then speedFactor = 1.25
	else speedFactor = 1.35 end
	
	local distanceFactor = 1.0
	if distance > DISTANCE_BRACKETS.FAR then distanceFactor = 1.15
	elseif distance > DISTANCE_BRACKETS.MID_FAR then distanceFactor = 1.10
	elseif distance > DISTANCE_BRACKETS.MID then distanceFactor = 1.05
	elseif distance < DISTANCE_BRACKETS.MELEE then distanceFactor = 0.92 end
	
	local pingFactor = 1.0 + (math.min(ping, 300) / 1000)
	return (baseDivisor * speedFactor * distanceFactor * pingFactor) * speedDivisorMultiplier
end

function AutoParry_Improved.CalculateSmartDistanceFactor(distance, speed, ping)
	local speedMultiplier = 1.0 + math.min(speed / 1500, 0.4)
	local pingMultiplier = 1.0 + (ping / 1000) * 0.3
	local baseFactor = 1.0
	
	if distance <= DISTANCE_BRACKETS.MELEE then baseFactor = ACCURACY_MULTIPLIERS.DISTANCE_MELEE
	elseif distance <= DISTANCE_BRACKETS.CLOSE then baseFactor = ACCURACY_MULTIPLIERS.DISTANCE_CLOSE
	elseif distance <= DISTANCE_BRACKETS.MID_CLOSE then baseFactor = ACCURACY_MULTIPLIERS.DISTANCE_MID_CLOSE
	elseif distance <= DISTANCE_BRACKETS.MID then baseFactor = ACCURACY_MULTIPLIERS.DISTANCE_MID
	elseif distance <= DISTANCE_BRACKETS.MID_FAR then baseFactor = ACCURACY_MULTIPLIERS.DISTANCE_MID_FAR
	elseif distance <= DISTANCE_BRACKETS.FAR then baseFactor = ACCURACY_MULTIPLIERS.DISTANCE_FAR
	else baseFactor = ACCURACY_MULTIPLIERS.DISTANCE_EXTREME end
	
	return baseFactor * speedMultiplier * pingMultiplier
end

function AutoParry_Improved.GetSpeedMultiplier(speed)
	if speed >= SPEED_BRACKETS.HYPERSONIC then return ACCURACY_MULTIPLIERS.SPEED_HYPERSONIC
	elseif speed >= SPEED_BRACKETS.EXTREME then return ACCURACY_MULTIPLIERS.SPEED_EXTREME
	elseif speed >= SPEED_BRACKETS.VERY_FAST then return ACCURACY_MULTIPLIERS.SPEED_VERY_FAST
	elseif speed >= SPEED_BRACKETS.FAST then return ACCURACY_MULTIPLIERS.SPEED_FAST
	elseif speed >= SPEED_BRACKETS.MEDIUM_FAST then return ACCURACY_MULTIPLIERS.SPEED_MEDIUM_FAST
	elseif speed >= SPEED_BRACKETS.MEDIUM then return ACCURACY_MULTIPLIERS.SPEED_MEDIUM
	elseif speed >= SPEED_BRACKETS.SLOW then return ACCURACY_MULTIPLIERS.SPEED_SLOW
	elseif speed >= SPEED_BRACKETS.VERY_SLOW then return ACCURACY_MULTIPLIERS.SPEED_VERY_SLOW
	else return 1.3 end
end

function AutoParry_Improved.CalculateAdaptivePingCompensation(ping, speed)
	local baseFactor = 1.0
	if ping >= PING_BRACKETS.CRITICAL then baseFactor = ACCURACY_MULTIPLIERS.PING_CRITICAL
	elseif ping >= PING_BRACKETS.VERY_POOR then baseFactor = ACCURACY_MULTIPLIERS.PING_VERY_POOR
	elseif ping >= PING_BRACKETS.POOR then baseFactor = ACCURACY_MULTIPLIERS.PING_POOR
	elseif ping >= PING_BRACKETS.FAIR then baseFactor = ACCURACY_MULTIPLIERS.PING_FAIR
	elseif ping >= PING_BRACKETS.GOOD then baseFactor = ACCURACY_MULTIPLIERS.PING_GOOD
	else baseFactor = ACCURACY_MULTIPLIERS.PING_EXCELLENT end
	
	local speedAdjust = 1.0 + (math.min(speed - 600, 900) / 3000)
	return (ping / 1000) * baseFactor * speedAdjust
end

function AutoParry_Improved.DetectCurveAdvanced(ball, velocityHistory, dotHistories, playerPos)
	if not ball then return 0, false, false, false end
	local zoomies = ball:FindFirstChild('zoomies')
	if not zoomies then return 0, false, false, false end
	
	local velocity = zoomies.VectorVelocity
	local speed = velocity.Magnitude
	if speed < CURVE_COEFFICIENTS.MIN_CURVE_SPEED then return 0, false, false, false end
	if not velocityHistory or #velocityHistory < 2 then return 0, false, false, false end
	if not dotHistories or #dotHistories < 2 then return 0, false, false, false end
	
	local curveScore = 0
	local isBackwardsCurved = false
	local isHighCurved = false
	
	local ballYVelocity = velocity.Y
	local horizontalSpeed = math.sqrt(velocity.X^2 + velocity.Z^2)
	
	if ballYVelocity > CURVE_COEFFICIENTS.HIGH_CURVE_VERTICAL_MIN and 
	   horizontalSpeed > CURVE_COEFFICIENTS.HIGH_CURVE_HORIZONTAL_MIN then
		isHighCurved = true
		curveScore = curveScore + CURVE_COEFFICIENTS.HIGH_CURVE_WEIGHT
	end
	
	local ballPos = ball.Position
	local horizDir = Vector3.new(playerPos.X - ballPos.X, 0, playerPos.Z - ballPos.Z)
	
	if horizDir.Magnitude > 0 then
		horizDir = horizDir.Unit
		local awayFromPlayer = -horizDir
		local horizBallDir = Vector3.new(velocity.X, 0, velocity.Z)
		
		if horizBallDir.Magnitude > 0 then
			horizBallDir = horizBallDir.Unit
			local backwardsAngle = math.deg(math.acos(math.clamp(awayFromPlayer:Dot(horizBallDir), -1, 1)))
			local angleThreshold = CURVE_COEFFICIENTS.BACKWARDS_THRESHOLD_BASE
			local distance = (playerPos - ballPos).Magnitude
			
			if speed > SPEED_BRACKETS.VERY_FAST then
				angleThreshold = CURVE_COEFFICIENTS.BACKWARDS_THRESHOLD_CLOSE
			elseif speed > SPEED_BRACKETS.FAST then
				angleThreshold = angleThreshold - 5
			end
			
			if distance > DISTANCE_BRACKETS.MID then
				angleThreshold = angleThreshold - 8
			end
			
			if backwardsAngle < angleThreshold then
				isBackwardsCurved = true
				curveScore = curveScore + CURVE_COEFFICIENTS.BACKWARDS_WEIGHT
			end
		end
	end
	
	if #velocityHistory >= 4 then
		local prevVel = velocityHistory[#velocityHistory - 1]
		local ballDirection = velocity.Unit
		
		if prevVel.Magnitude > SPEED_BRACKETS.SLOW and speed > SPEED_BRACKETS.SLOW then
			local threshold = CURVE_COEFFICIENTS.DIRECTION_CHANGE_THRESHOLD_BASE
			if speed > SPEED_BRACKETS.VERY_FAST then
				threshold = 0.72
			elseif speed > SPEED_BRACKETS.FAST then
				threshold = 0.76
			end
			
			if prevVel.Unit:Dot(ballDirection) < threshold then
				curveScore = curveScore + CURVE_COEFFICIENTS.DIRECTION_CHANGE_WEIGHT
			end
		end
	end
	
	if #dotHistories >= 5 then
		local dotVariance = 0
		local hist = dotHistories
		
		for i = 2, #hist do
			dotVariance = dotVariance + math.abs(hist[i] - hist[i-1])
		end
		dotVariance = dotVariance / (#hist - 1)
		
		local varianceThreshold = CURVE_COEFFICIENTS.DOT_VARIANCE_WEIGHT / 10
		if speed > SPEED_BRACKETS.VERY_FAST then
			varianceThreshold = 0.12
		elseif speed > SPEED_BRACKETS.FAST then
			varianceThreshold = 0.10
		end
		
		if dotVariance > varianceThreshold then
			curveScore = curveScore + CURVE_COEFFICIENTS.DOT_VARIANCE_WEIGHT
		end
	end
	
	if #velocityHistory >= 4 then
		local speeds = {}
		for _, vel in ipairs(velocityHistory) do
			table.insert(speeds, vel.Magnitude)
		end
		
		local avgSpeed = 0
		for _, spd in ipairs(speeds) do avgSpeed = avgSpeed + spd end
		avgSpeed = avgSpeed / #speeds
		
		local variance = 0
		for _, spd in ipairs(speeds) do variance = variance + math.abs(spd - avgSpeed) end
		variance = variance / #speeds
		
		local varianceThreshold = avgSpeed * 0.18
		if variance > varianceThreshold then
			curveScore = curveScore + CURVE_COEFFICIENTS.SPEED_VARIANCE_WEIGHT
		end
	end
	
	local isCurved = curveScore >= 3.5 or isBackwardsCurved or isHighCurved
	return curveScore, isCurved, isBackwardsCurved, isHighCurved
end

function AutoParry_Improved.CalculateAdaptiveCurvePenalty(speed, distance, curveScore, isBackwardsCurved, isHighCurved)
	if curveScore < 1 then return 0 end
	
	local severity = curveScore / 6
	severity = math.min(severity, 1.0)
	
	local basePenalty = 0
	if isHighCurved then
		if speed > SPEED_BRACKETS.EXTREME then basePenalty = 150
		elseif speed > SPEED_BRACKETS.VERY_FAST then basePenalty = 135
		elseif speed > SPEED_BRACKETS.FAST then basePenalty = 120
		elseif speed > SPEED_BRACKETS.MEDIUM_FAST then basePenalty = 105
		else basePenalty = 90 end
	elseif isBackwardsCurved then
		if speed > SPEED_BRACKETS.VERY_FAST then basePenalty = 105
		elseif speed > SPEED_BRACKETS.FAST then basePenalty = 92
		elseif speed > SPEED_BRACKETS.MEDIUM_FAST then basePenalty = 78
		else basePenalty = 65 end
	else
		if speed > SPEED_BRACKETS.VERY_FAST then basePenalty = 70
		elseif speed > SPEED_BRACKETS.FAST then basePenalty = 62
		elseif speed > SPEED_BRACKETS.MEDIUM_FAST then basePenalty = 52
		else basePenalty = 42 end
	end
	
	local distanceModifier = 1.0
	if distance > DISTANCE_BRACKETS.FAR then
		distanceModifier = 0.45
	elseif distance > DISTANCE_BRACKETS.MID_FAR then
		distanceModifier = 0.58
	elseif distance > DISTANCE_BRACKETS.MID then
		distanceModifier = 0.70
	elseif distance > DISTANCE_BRACKETS.CLOSE then
		distanceModifier = 0.82
	elseif distance <= DISTANCE_BRACKETS.MELEE then
		distanceModifier = 0.65
	end
	
	return basePenalty * distanceModifier * (0.5 + severity)
end

function AutoParry_Improved.CalculateFinalParryAccuracy(
	speed, distance, ping, speedDivisorMultiplier, playerVel, ballVel,
	curveScore, isBackwardsCurved, isHighCurved, velocityHistory, dotHistories)
	
	local pingComp = AutoParry_Improved.CalculateAdaptivePingCompensation(ping, speed)
	local speedDiv = AutoParry_Improved.CalculateAdaptiveSpeedDivisor(speed, speedDivisorMultiplier, distance, ping)
	local distFactor = AutoParry_Improved.CalculateSmartDistanceFactor(distance, speed, ping)
	local speedComponent = math.max(speed / speedDiv, ACCURACY_BASE.PARRY_WINDOW_MIN)
	local speedMult = AutoParry_Improved.GetSpeedMultiplier(speed)
	
	local baseAccuracy = pingComp + speedComponent
	baseAccuracy = baseAccuracy * distFactor * speedMult
	baseAccuracy = math.max(baseAccuracy, ACCURACY_BASE.PARRY_WINDOW_MIN)
	
	local curvePenalty = AutoParry_Improved.CalculateAdaptiveCurvePenalty(speed, distance, curveScore, isBackwardsCurved, isHighCurved)
	baseAccuracy = baseAccuracy - curvePenalty
	
	if playerVel and ballVel then
		local relativeVel = (ballVel - playerVel).Magnitude
		if relativeVel > SPEED_BRACKETS.FAST then
			baseAccuracy = baseAccuracy * 1.18
		elseif relativeVel < SPEED_BRACKETS.SLOW then
			baseAccuracy = baseAccuracy * 1.08
		end
	end
	
	baseAccuracy = math.max(baseAccuracy, ACCURACY_BASE.PARRY_WINDOW_MIN)
	baseAccuracy = math.min(baseAccuracy, ACCURACY_BASE.PARRY_WINDOW_MAX)
	
	return baseAccuracy
end

function AutoParry_Improved.ShouldParryWithPrediction(
	ballPos, ballVel, ballSpeed, playerPos, playerVel, distance, parryAccuracy, ping)
	
	local predictions = AutoParry_Improved.PredictTrajectory(ballPos, ballVel, playerPos, playerVel, ping, 2)
	
	for _, pred in ipairs(predictions) do
		if pred.distance <= parryAccuracy * 1.05 then
			return true, pred.distance, pred.time
		end
	end
	
	local safetyMargin = (ping / 1000) * ballSpeed * 0.4
	local adjustedAccuracy = parryAccuracy + safetyMargin
	
	if distance <= adjustedAccuracy then
		return true, distance, 0
	end
	
	if distance <= parryAccuracy * 0.92 then
		return true, distance, 0
	end
	
	return false, distance, nil
end

function AutoParry_Improved.UpdateBallHistoryOptimized(ball, velocityHistory, dotHistories, maxHistory)
	local zoomies = ball:FindFirstChild('zoomies')
	if not zoomies then return false end
	
	local velocity = zoomies.VectorVelocity
	local playerPos = game:GetService('Players').LocalPlayer.Character.PrimaryPart.Position
	
	if not velocityHistory[ball] then velocityHistory[ball] = {} end
	table.insert(velocityHistory[ball], velocity)
	if #velocityHistory[ball] > maxHistory then
		table.remove(velocityHistory[ball], 1)
	end
	
	if not dotHistories[ball] then dotHistories[ball] = {} end
	local direction = (playerPos - ball.Position).Unit
	local ballDirection = velocity.Unit
	local dot = direction:Dot(ballDirection)
	table.insert(dotHistories[ball], dot)
	if #dotHistories[ball] > maxHistory then
		table.remove(dotHistories[ball], 1)
	end
	
	return true
end

