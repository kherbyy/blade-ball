			local pac = Players.PlayerAdded:Connect(function(player)
				createLabel(player)
				local cc = player.CharacterAdded:Connect(function() createLabel(player) end)
				table.insert(ConnectionsTable, cc)
			end)
			table.insert(ConnectionsTable, pac)
		else
			for _, conn in pairs(ConnectionsTable) do if conn.Connected then conn:Disconnect() end end
			ConnectionsTable = {}
			for player, text in pairs(Billboard_Labels) do
