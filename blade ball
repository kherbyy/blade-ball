local function KeypressAPC(parryType)
	if not LocalPlayer.Character or not LocalPlayer.Character.PrimaryPart then return end
	-- ✓ Use SelectedParryType if no parryType provided
	local actualParryType = parryType or SelectedParryType
	print("[KEYPRESS_APC] Starting with parry type: " .. tostring(actualParryType))
	local parryData = AutoParry.Parry_Data(actualParryType)
	if not parryData then 
		print("[KEYPRESS_APC] ERROR: parryData is nil!")
		return 
	end
	print("[KEYPRESS_APC] Got parryData - Target should curve: " .. tostring(actualParryType))
	local cam    = Workspace.CurrentCamera
	local orig   = cam.CFrame
	local rndAng = CFrame.Angles(math.rad(math.random(-5,5)), math.rad(math.random(-5,5)), math.rad(math.random(-2,2)))
	local target = parryData[2] * rndAng
	local startTime = tick()
	local duration  = 0.11 + math.random(-10,10)/1000
	local conn
	conn = RunService.Heartbeat:Connect(function()
		local elapsed = tick() - startTime
		if elapsed >= duration then
			conn:Disconnect()
			print("[KEYPRESS_APC] Clicking now...")
			SimulateParry()
			task.wait(0.25 + math.random(-30,30)/1000)
			local backStart = tick()
			local backDuration = 0.14
			local backConn
			backConn = RunService.Heartbeat:Connect(function()
				local backElapsed = tick() - backStart
				if backElapsed >= backDuration then backConn:Disconnect(); return end
				local alpha = backElapsed / backDuration
				cam.CFrame = target:Lerp(orig, 1-(1-alpha)^2)
			end)
			return
		end
		local alpha = elapsed / duration
		alpha = alpha^2
		cam.CFrame = orig:Lerp(target, alpha)
	end)
end

