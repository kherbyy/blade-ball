					local pingedValued = game:GetService('Stats').Network.ServerStatsItem['Data Ping']:GetValue()
					local playerPos = LocalPlayer.Character.PrimaryPart.Position
					local ballPos = ball.Position
					local playerVel = LocalPlayer.Character.PrimaryPart.Velocity
					local distance = (playerPos - ballPos).Magnitude
					local speed    = velocity.Magnitude
					
					if AutoPostParry then
						if not PostParryVelocityHistory[ball] then PostParryVelocityHistory[ball] = {} end
						table.insert(PostParryVelocityHistory[ball], speed)
						if #PostParryVelocityHistory[ball] > 15 then table.remove(PostParryVelocityHistory[ball], 1) end
						if ballTarget and ballTarget ~= "" and ballTarget ~= tostring(LocalPlayer) then
							PostParryTarget = ballTarget
						end
					end
					
					local curveScore, isCurved, isBackwardsCurved, isHighCurved = AutoParry_Improved.DetectCurveAdvanced(
						ball,
						AutoParry.Velocity_History[ball],
						AutoParry.Dot_Histories[ball],
						playerPos
					)
					
					if isBackwardsCurved then wasBackwards[ball] = true end
					
					local tornado = Runtime:FindFirstChild('Tornado')
					if ball:FindFirstChild('AeroDynamicSlashVFX') then
						Debris:AddItem(ball.AeroDynamicSlashVFX, 0); Tornado_Time = tick()
					end
					if tornado then
						local elapsedTornado = tick() - Tornado_Time
						local tornadoDuration = (tornado:GetAttribute('TornadoTime') or 1) + 0.314159
						if elapsedTornado < tornadoDuration then continue end
					end
					
					local singularityCape = LocalPlayer.Character.PrimaryPart:FindFirstChild('SingularityCape')
					local Predicted_Dot = (playerPos - ballPos).Unit:Dot(velocity.Unit)
					if oneTarget == tostring(LocalPlayer) and Predicted_Dot < -0.3 then continue end
					if Singularity_Detection and singularityCape then continue end
					
					local hotbar   = LocalPlayer.PlayerGui:FindFirstChild('Hotbar')
					local abilities = LocalPlayer.Character:FindFirstChild('Abilities')
					local durationUI = hotbar and hotbar:FindFirstChild('Ability') and hotbar.Ability:FindFirstChild('Duration') and hotbar.Ability.Duration.Visible
					local infinityAbility = abilities and abilities:FindFirstChild('Infinity')
					local usingInfinity   = durationUI and infinityAbility and infinityAbility.Enabled and Infinity_Ball
					if Infinity_Detection and usingInfinity then continue end
					
					local timeholeAbility = abilities and abilities:FindFirstChild('Time Hole')
					if durationUI and timeholeAbility and timeholeAbility.Enabled then continue end
					
					if AntiPhantomEnabled and Phantom and LocalPlayer.Character:GetAttribute('Parrying') then
						ContextActionService:BindAction('BlockPlayerMovement', BlockMovement, false,
							Enum.KeyCode.W, Enum.KeyCode.A, Enum.KeyCode.S, Enum.KeyCode.D, Enum.UserInputType.Touch)
						LocalPlayer.Character.Humanoid.WalkSpeed = 36
						LocalPlayer.Character.Humanoid:MoveTo(ball.Position)
						task.spawn(function()
							repeat
								if LocalPlayer.Character.Humanoid.WalkSpeed ~= 36 then
									LocalPlayer.Character.Humanoid.WalkSpeed = 36
								end
								task.wait()
							until not Phantom
						end)
						ball:GetAttributeChangedSignal('target'):Once(function()
							ContextActionService:UnbindAction('BlockPlayerMovement')
							Phantom = false
							LocalPlayer.Character.Humanoid:MoveTo(LocalPlayer.Character.HumanoidRootPart.Position)
							LocalPlayer.Character.Humanoid.WalkSpeed = 10
							task.delay(3, function() LocalPlayer.Character.Humanoid.WalkSpeed = 36 end)
						end)
					end
					
					local parryAccuracy = AutoParry_Improved.CalculateFinalParryAccuracy(
						speed,
						distance,
						pingedValued,
						Speed_Divisor_Multiplier,
						playerVel,
						velocity,
						curveScore,
						isBackwardsCurved,
						isHighCurved,
						AutoParry.Velocity_History[ball],
						AutoParry.Dot_Histories[ball]
					)
					
					-- ✓ BOOST ACCURACY FOR FAST BALLS (to handle Auto Spam transitions)
					-- When ball is very fast from Auto Spam, give Auto Parry a better chance
					if speed > 500 then
						local fastBallBoost = 1.0 + math.min((speed - 500) / 1000, 0.3)  -- Up to 30% boost
						parryAccuracy = parryAccuracy * fastBallBoost
						if speed > 800 then
							print("[AUTO_PARRY] FAST BALL BOOST applied: " .. tostring(math.floor(speed)) .. " spd | accuracy boosted by " .. tostring(math.floor((fastBallBoost - 1) * 100)) .. "%")
						end
					end
					
					-- Debug: Show how accuracy setting affects parry decisions
					if speed > 600 then
						print("[AUTO_PARRY_CALC] Speed: " .. tostring(math.floor(speed)) .. " | Distance: " .. tostring(math.floor(distance)) .. " | ParryAccuracy: " .. tostring(math.floor(parryAccuracy)) .. " | Multiplier: " .. string.format("%.2f", Speed_Divisor_Multiplier))
					end
					
					local shouldParry, decisionDistance, predictionTime = AutoParry_Improved.ShouldParryWithPrediction(
						ballPos,
						velocity,
						speed,
						playerPos,
						playerVel,
						distance,
						parryAccuracy,
						pingedValued
					)
					
					if ballTarget == tostring(LocalPlayer) and shouldParry and Phantom then
						if AutoParryType == "Keypress" then KeypressAPC(SelectedParryType) else SimulateParry() end
						Parries += 1; task.delay(0.5, function() if Parries > 0 then Parries -= 1 end end)
						Parried = true
					end
					
					if ballTarget == tostring(LocalPlayer) and shouldParry and not Phantom then
						if Death_Slash_Detection and DeathSlashDetection then continue end
						local parryTime = os.clock()
						if (parryTime - LastParry) > 0.5 then AutoParry.ParryAnim(false) end
						local useAbility = false
						if HighPingProtection and GetAveragePing() > 130 then
							useAbility = true; Use_Ability:Fire()
						end
						if not useAbility then
							print("[AUTO_PARRY_LOOP] AutoParryType=" .. tostring(AutoParryType) .. " | SelectedParryType=" .. tostring(SelectedParryType) .. " | Has Remotes=" .. tostring(next(ParryRemotes) ~= nil))
							
							-- Always try Remote first if available
							if Is_Supported_Test and next(ParryRemotes) then
								print("[AUTO_PARRY_LOOP] Using REMOTE with curve: " .. tostring(SelectedParryType))
								AutoParry.PerformRemoteParry(SelectedParryType)
							-- Fallback to Keypress
							elseif AutoParryType == "Keypress" or AutoParryType ~= "Remote" then
								print("[AUTO_PARRY_LOOP] Using KEYPRESS with curve: " .. tostring(SelectedParryType))
								KeypressAPC(SelectedParryType)
							-- Last resort
							else
								print("[AUTO_PARRY_LOOP] Using SIMULATE with curve: " .. tostring(SelectedParryType))
								SimulateParry()
							end
							Parries += 1; task.delay(0.5, function() if Parries > 0 then Parries -= 1 end end)
							
							-- ✓ AUTO PARRY FAILED - Increment auto parry counter for Auto Spam Parry
							if distance <= CLOSE_RANGE_THRESHOLD then
								AutoParryCloseRangeCounter = AutoParryCloseRangeCounter + 1
							end
						end
						LastParry = parryTime; Parried = true; wasBackwards[ball] = false
						local lastParrys = tick()
						repeat RunService.PreSimulation:Wait() until (tick()-lastParrys) >= 1 or not Parried
						Parried = false
					end
				end
			end)
		elseif Connections["autoParry"] then
			Connections["autoParry"]:Disconnect(); Connections["autoParry"] = nil
			if Connections["autoPostParry_deathMonitor"] then
				Connections["autoPostParry_deathMonitor"]:Disconnect()
				Connections["autoPostParry_deathMonitor"] = nil
			end
			PostParryTarget = nil; PostParryVelocityHistory = {}; PostParryScheduled = {}
		end
	end
})

