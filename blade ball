function Config:save(file_name, config)
	local ok, err = pcall(function()
		writefile('click/' .. file_name .. '.json', HttpService:JSONEncode(config))
	end)
	if not ok then warn('failed to save config', err) end
end

function Config:load(file_name, config)
	local ok, result = pcall(function()
		if not isfile('click/' .. file_name .. '.json') then
			self:save(file_name, config)
			return
		end
		local flags = readfile('click/' .. file_name .. '.json')
		if not flags then
			self:save(file_name, config)
			return
		end
		return HttpService:JSONDecode(flags)
	end)
	if not ok then warn('failed to load config', result) end
	if not result then
		result = { _flags = {}, _keybinds = {}, _library = {} }
	end
	return result
end

